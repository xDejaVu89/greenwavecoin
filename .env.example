# ==============================================
# GreenWaveCoin Environment Configuration
# ==============================================

# ==============================================
# PRIVATE KEY (REQUIRED FOR ALL DEPLOYMENTS)
# ==============================================
PRIVATE_KEY=your_private_key_here

# ==============================================
# API KEYS FOR CONTRACT VERIFICATION (REQUIRED)
# ==============================================
ETHERSCAN_API_KEY=your_etherscan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key
BSCSCAN_API_KEY=your_bscscan_api_key
ARBISCAN_API_KEY=your_arbiscan_api_key
BASESCAN_API_KEY=your_basescan_api_key

# ==============================================
# PRODUCTION ADDRESSES (REQUIRED FOR MAINNET)
# ==============================================
GNOSIS_SAFE_ADDRESS=0x0000000000000000000000000000000000000000
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000

# ==============================================
# MONITORING & ALERTS (REQUIRED FOR PRODUCTION)
# ==============================================
ALERT_WEBHOOK_URL=https://your-webhook-url-here
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your_webhook
SLACK_WEBHOOK=https://hooks.slack.com/services/your/webhook
ALERT_THRESHOLD_TOKENS=1000

# ==============================================
# RPC ENDPOINTS (Optional - defaults provided)
# ==============================================
ARBITRUM_RPC=your_arbitrum_rpc_url
BSC_RPC=your_bsc_rpc_url
BASE_RPC=your_base_rpc_url
SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/yourAlchemyKeyHere

# ==============================================
# GAS REPORTING (Optional)
# ==============================================
REPORT_GAS=true
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key

# ==============================================
# DEPLOYED ADDRESSES (Auto-populated)
# ==============================================
TOKEN_ADDRESS=
STAKING_ADDRESS=
TIMELOCK_ADDRESS=
PROXY_ADDRESS=

TOKEN_DECIMALS=18

# ==============================================
# TOKENOMICS PLANNING (Optional, off-chain guidance)
# ==============================================
# Target initial circulating market cap in USD (e.g., 21000000 for $21M)
TARGET_MARKET_CAP_USD=21000000

# Circulating tokens at TGE (count only freely tradable tokens, exclude treasury, timelock, staking rewards, vesting)
# Provide absolute token amount (not wei), e.g., 300000 means 300,000 tokens
TGE_CIRC_TOKENS=300000

# Percentage of circulating tokens to seed into the initial DEX liquidity pool (e.g., 10-25)
LP_TOKENS_PERCENT=15

# Estimated ETH/USD price at the time of pool seeding (used to compute required ETH for LP)
ETH_PRICE_USD=3500

# Comma-separated list of addresses to exclude when computing circulating supply
# (e.g., timelock, treasury, staking contract, vesting contracts, burn address)
EXCLUDE_ADDRESSES=0x0000000000000000000000000000000000000000,0x000000000000000000000000000000000000dEaD
\n+# Production total supply tokens (used by deploy-production initializeWithSupply)
TOTAL_SUPPLY_TOKENS=21000000

# ==============================================
# SMALL LP LAUNCH (Budget Mode - Optional)
# ==============================================
# If set, scripts derive LP token amount from these instead of percentages.
# Example: BUDGET_USD=50, PRICE_USD=0.05 -> 1,000 tokens + ~$50 token-side value.
BUDGET_USD=
PRICE_USD=

# ==============================================
# BACKEND COORDINATOR (AI Research Network)
# ==============================================
# Port the coordinator listens on
PORT=3000

# SQLite database file path
DB_PATH=./data/gwc.db

# API key for admin endpoints (task creation, result listing)
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=CHANGE_ME_ADMIN_KEY

# API key for worker endpoints (task fetch, result submission)
# Generate with: openssl rand -hex 32
WORKER_API_KEY=CHANGE_ME_WORKER_KEY

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# ==============================================
# AI WORKER (set on contributor machines)
# ==============================================
# Backend coordinator URL
BACKEND_BASE_URL=http://your-server:3000

# Worker's Ethereum wallet address (receives GWC rewards)
WORKER_WALLET=0xYOUR_WALLET_ADDRESS

# Seconds between task polls
POLL_INTERVAL=30

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO